{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm run *)",
      "Bash(npx:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(gh repo view:*)",
      "Bash(gh issue view:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.*.local)"
    ]
  }
}
